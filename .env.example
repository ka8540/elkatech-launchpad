NODE_ENV=development
POSTGRES_URL=
KV_URL=
DATABASE_URL=postgres://elkatech:elkatech@127.0.0.1:5432/elkatech
INTERNAL_SERVICE_TOKEN=dev-internal-token
APP_BASE_URL=http://127.0.0.1:8080
GATEWAY_URL=http://127.0.0.1:4000
AUTH_SERVICE_URL=http://127.0.0.1:4001
CATALOG_SERVICE_URL=http://127.0.0.1:4002
SERVICE_DESK_URL=http://127.0.0.1:4003
NOTIFICATION_SERVICE_URL=http://127.0.0.1:4004
SESSION_COOKIE_NAME=elkatech_session
CSRF_COOKIE_NAME=elkatech_csrf
SESSION_TTL_HOURS=168
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM="ElkaTech Support <ka8540@g.rit.edu>"
SMTP_SECURE=false
BOOTSTRAP_ADMIN_EMAIL=admin@elkatech.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# Firebase Admin SDK (backend) — never commit real values.
# FIREBASE_PRIVATE_KEY may contain escaped newlines; we replace "\n" with real newlines at load time.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase web client (frontend, Vite-safe) — these are public web app config keys.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# AWS SES (notification service) — leave blank locally to keep using
# SMTP/Mailpit. When SES_FROM_EMAIL + AWS credentials are set in
# production, the notification service sends the two transactional flows
# (admin invite + request claimed) via SES SendTemplatedEmail.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=no-reply@elkatech.com
SES_ACCOUNT_ADDED_TEMPLATE=ElkaTechAccountAdded
SES_REQUEST_CLAIMED_TEMPLATE=ElkaTechRequestClaimed

# Cloudflare R2 (service-request photo/video attachments) — S3-compatible
# object storage. Set all four required vars to enable attachments; the
# browser uploads straight to R2 via short-lived presigned URLs, so files
# never pass through the serverless functions. Leave blank to disable
# attachments cleanly.
#   R2_ENDPOINT defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
#   R2_PUBLIC_BASE_URL is only needed if the bucket is intentionally public;
#   otherwise reads use signed GET URLs.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
MAX_REQUEST_ATTACHMENT_MB=25
ALLOWED_REQUEST_ATTACHMENT_TYPES=image/jpeg,image/png,image/webp,video/mp4,video/quicktime,video/webm
