# Environment files (NEVER commit these)
.env
.env.*
!.env.example

# Firebase service account secrets (NEVER commit these)
*.service-account.json
firebase-service-account*.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel

# Terraform (never commit state, plans, or filled tfvars)
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
terraform.tfvars
*.auto.tfvars
