{
  "name": "elkatech-service-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n web,gateway,auth,catalog,desk,notify \"npm run dev:web\" \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:catalog\" \"npm run dev:service-desk\" \"npm run dev:notification\"",
    "dev:web": "npm run dev -w @elkatech/web",
    "dev:gateway": "npm run dev -w @elkatech/gateway",
    "dev:auth": "npm run dev -w @elkatech/auth",
    "dev:catalog": "npm run dev -w @elkatech/catalog",
    "dev:service-desk": "npm run dev -w @elkatech/service-desk",
    "dev:notification": "npm run dev -w @elkatech/notification",
    "dev:infra": "docker compose up -d postgres mailpit",
    "build": "npm run build -w @elkatech/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:bootstrap-admin": "tsx scripts/bootstrap-admin.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^6.4.17",
    "concurrently": "^9.1.2",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^20.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
