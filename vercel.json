{
  "buildCommand": "npm run build -w @elkatech/web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/api/internal-auth/(.*)", "destination": "/api/auth.ts" },
    { "source": "/api/internal-catalog/(.*)", "destination": "/api/catalog.ts" },
    { "source": "/api/internal-service-desk/(.*)", "destination": "/api/service-desk.ts" },
    { "source": "/api/internal-notification/(.*)", "destination": "/api/notification.ts" },
    { "source": "/api/(.*)", "destination": "/api/gateway.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
