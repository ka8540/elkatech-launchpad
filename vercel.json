{
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",

  "rewrites": [
    {
      "source": "/api/internal-auth/(.*)",
      "destination": "/api/auth.mjs"
    },
    {
      "source": "/api/internal-catalog/(.*)",
      "destination": "/api/catalog.mjs"
    },
    {
      "source": "/api/internal-service-desk/(.*)",
      "destination": "/api/service-desk.mjs"
    },
    {
      "source": "/api/internal-notification/(.*)",
      "destination": "/api/notification.mjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/gateway.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
